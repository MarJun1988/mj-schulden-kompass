generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum DebtDeletionStatus {
  PENDING
  REJECTED
}

enum DebtPaymentStatus {
  PENDING
  REJECTED
}

enum DebtCreditEntryType {
  GRANT
  PAYMENT
  TRANSFER
}

enum MailDeliveryStatus {
  PENDING
  SENDING
  SENT
  FAILED
}

model Transaction {
  id        String          @id @default(cuid())
  title     String
  amount    Decimal         @db.Decimal(12, 2)
  type      TransactionType
  bookedAt  DateTime        @default(now())
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model User {
  id                         String    @id @default(cuid())
  name                       String
  email                      String    @unique
  passwordHash               String
  emailVerifiedAt            DateTime?
  emailVerificationToken     String?   @unique
  emailVerificationExpiresAt DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  debtsCreated Debt[] @relation("DebtCreator")
  creditsGranted DebtCredit[] @relation("DebtCreditCreator")

  @@index([email])
  @@index([emailVerificationToken])
}

model Debt {
  id                  String              @id @default(cuid())
  debtorName          String
  debtorEmail         String
  amount              Decimal             @db.Decimal(12, 2)
  purpose             String
  comment             String?
  category            String
  debtDate            DateTime
  paidAt              DateTime?
  paymentStatus       DebtPaymentStatus?
  paymentReason       String?
  paymentRequestedAt  DateTime?
  paymentRejectedAt   DateTime?
  deletionStatus      DebtDeletionStatus?
  deletionReason      String?
  deletionRequestedAt DateTime?
  deletionRejectedAt  DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  creatorId String
  creator   User   @relation("DebtCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@index([debtorEmail])
  @@index([paidAt])
  @@index([paymentStatus])
  @@index([deletionStatus])
}

model DebtCredit {
  id          String   @id @default(cuid())
  creatorId   String
  debtorName  String
  debtorEmail String
  balance     Decimal  @default(0) @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator User              @relation("DebtCreditCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  entries DebtCreditEntry[]

  @@unique([creatorId, debtorEmail])
  @@index([creatorId])
  @@index([debtorEmail])
}

model DebtCreditEntry {
  id        String              @id @default(cuid())
  creditId  String
  type      DebtCreditEntryType
  amount    Decimal             @db.Decimal(12, 2)
  note      String?
  debtId    String?
  createdAt DateTime            @default(now())

  credit DebtCredit @relation(fields: [creditId], references: [id], onDelete: Cascade)

  @@index([creditId])
  @@index([debtId])
  @@index([createdAt])
}

model AppVersion {
  id          String   @id
  version     String   @unique
  title       String
  description String
  notes       String[]
  releasedAt  DateTime
  createdAt   DateTime @default(now())

  @@index([releasedAt])
}

model QueuedMail {
  id            String             @id @default(cuid())
  to            String
  subject       String
  text          String
  html          String
  status        MailDeliveryStatus @default(PENDING)
  attempts      Int                @default(0)
  maxAttempts   Int                @default(10)
  lastError     String?
  nextAttemptAt DateTime           @default(now())
  lockedAt      DateTime?
  sentAt        DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([status, nextAttemptAt])
  @@index([lockedAt])
  @@index([createdAt])
}
