{
  "name": "@schuldkompass/docs",
  "version": "0.1.5",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev . --host 0.0.0.0",
    "docs:build": "vitepress build .",
    "docs:preview": "vitepress preview . --host 0.0.0.0",
    "format": "oxfmt --write .vitepress/config.ts api development guide index.md package.json",
    "format:check": "oxfmt --check .vitepress/config.ts api development guide index.md package.json",
    "lint": "oxlint .vitepress/config.ts --import-plugin --node-plugin --promise-plugin --deny-warnings",
    "lint:fix": "oxlint .vitepress/config.ts --import-plugin --node-plugin --promise-plugin --fix"
  },
  "devDependencies": {
    "vitepress": "^1.6.4"
  }
}
