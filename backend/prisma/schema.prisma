generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum DebtDeletionStatus {
  PENDING
  REJECTED
}

model Transaction {
  id        String          @id @default(cuid())
  title     String
  amount    Decimal         @db.Decimal(12, 2)
  type      TransactionType
  bookedAt  DateTime        @default(now())
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model User {
  id                         String    @id @default(cuid())
  name                       String
  email                      String    @unique
  passwordHash               String
  emailVerifiedAt            DateTime?
  emailVerificationToken     String?   @unique
  emailVerificationExpiresAt DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  debtsCreated Debt[] @relation("DebtCreator")

  @@index([email])
  @@index([emailVerificationToken])
}

model Debt {
  id                  String              @id @default(cuid())
  debtorName          String
  debtorEmail         String
  amount              Decimal             @db.Decimal(12, 2)
  purpose             String
  comment             String?
  category            String
  debtDate            DateTime
  paidAt              DateTime?
  deletionStatus      DebtDeletionStatus?
  deletionReason      String?
  deletionRequestedAt DateTime?
  deletionRejectedAt  DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  creatorId String
  creator   User   @relation("DebtCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@index([debtorEmail])
  @@index([paidAt])
  @@index([deletionStatus])
}

model AppVersion {
  id          String   @id
  version     String   @unique
  title       String
  description String
  notes       String[]
  releasedAt  DateTime
  createdAt   DateTime @default(now())

  @@index([releasedAt])
}
