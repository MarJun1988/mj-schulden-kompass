# Docker image tag. The GitLab deploy job exports VERSION automatically.
VERSION=v1.0.5

# Testing only: docker-compose.testing.yml defaults to these GitLab registry images
# and the testing deploy job uses VERSION=latest for dev branches.
# GITLAB_IMAGE_BACKEND=registry.gitlab.com/marjun1988/mj-schulden-kompass/backend
# GITLAB_IMAGE_FRONTEND=registry.gitlab.com/marjun1988/mj-schulden-kompass/frontend
# GITLAB_IMAGE_DOCS=registry.gitlab.com/marjun1988/mj-schulden-kompass/docs
# GITLAB_IMAGE_EDGE=registry.gitlab.com/marjun1988/mj-schulden-kompass/edge

# Public ports
EDGE_HTTP_PORT=80
EDGE_HTTPS_PORT=443
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-secure-grafana-password

# App
APP_URL=https://schuldkompass.example.com
JWT_SECRET=replace-with-a-long-random-secret
LOG_LEVEL=info
GITHUB_RELEASE_CHECK_ENABLED=true
GITHUB_RELEASE_REPOSITORY=MarJun1988/mj-schulden-kompass
GITHUB_RELEASE_CHECK_TTL_MINUTES=360
GITHUB_RELEASE_CHECK_TIMEOUT_MS=3000

# Database
POSTGRES_DB=mj_money
POSTGRES_USER=mj_money
POSTGRES_PASSWORD=replace-with-a-secure-database-password
DATABASE_URL=postgresql://mj_money:replace-with-a-secure-database-password@postgres:5432/mj_money?schema=public

# Mail
MAIL_FROM=SchuldKompass <noreply@example.com>
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=replace-with-your-smtp-password
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=15000
MAIL_RETRY_ENABLED=true
MAIL_RETRY_INTERVAL_MINUTES=30
MAIL_RETRY_MAX_ATTEMPTS=10
MAIL_RETRY_BATCH_SIZE=20
